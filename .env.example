# Copy to .env.local and fill in real values from your Supabase project
# (Project Settings → API).

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only — NEVER expose to the browser. Used for admin writes/uploads
# that bypass RLS from trusted server code.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Public storage bucket name for uploaded hero/gallery images.
NEXT_PUBLIC_SUPABASE_BUCKET="mosque-images"
