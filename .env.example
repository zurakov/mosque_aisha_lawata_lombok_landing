# Copy to .env and fill in real values.

# SQLite (default). To use Postgres later, set provider="postgresql" in
# prisma/schema.prisma and point this at your Postgres connection string.
# With Prisma 6 the file: path is relative to prisma/, so this lands at prisma/dev.db
DATABASE_URL="file:./dev.db"

# Admin dashboard credentials (protects /admin and /api/admin/*).
ADMIN_PASSWORD="set-a-strong-password"
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="set-a-long-random-secret"
