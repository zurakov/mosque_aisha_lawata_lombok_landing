// Prisma schema for the mosque site's editable content.
// Datasource is SQLite for simplicity; switch `provider` to "postgresql" and
// update DATABASE_URL to migrate to Postgres later — the models stay the same.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Day {
  Mon
  Tue
  Wed
  Thu
  Fri
  Sat
  Sun
}

enum Audience {
  ikhwan
  akhwat
  umum
}

/// A single weekly kajian (study circle) entry, editable from /admin.
model ScheduleEntry {
  id        String   @id @default(cuid())
  day       Day
  time      String
  topic     String
  ustadz    String
  audience  Audience @default(umum)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
